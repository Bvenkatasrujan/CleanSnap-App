{
  "expo": {
    "name": "CleanSnap App",
    "slug": "cleansnap-app",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F0FDF4"
    },
    "android": {
      "package": "com.cleansnap.app",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F0FDF4"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cleansnap.app"
    },
    "userInterfaceStyle": "light",
    "backgroundColor": "#F0FDF4",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "CleanSnap App needs your location to tag the reported area."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "CleanSnap App needs gallery access to attach a photo to your report.",
          "cameraPermission": "CleanSnap App needs camera access to take a photo for the report."
        }
      ],
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "35d9d313-8d83-4949-9b16-333074ae2b4e"
      }
    }
  }
}
